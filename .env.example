# --- General ---
APP_NAME=crypto-mvp # Human-readable app name used in settings/bootstrap logs
ENVIRONMENT=development # Runtime environment label (for example development, staging, production)
LOG_LEVEL=INFO # Global log verbosity for service logging
RUN_MODE=paper # High-level execution mode used by application settings
SERVICE_NAME=collector # Service identity used by bootstrap logging/metadata

# --- Database ---
DB_HOST=localhost # Postgres host used by SQLAlchemy connection URL
DB_PORT=5432 # Postgres TCP port used by SQLAlchemy connection URL
DB_NAME=crypto_mvp # Postgres database name used by SQLAlchemy connection URL
DB_USER=postgres # Postgres username used by SQLAlchemy connection URL
DB_PASSWORD=postgres # Postgres password used by SQLAlchemy connection URL
DB_ECHO=false # SQLAlchemy echo flag to print SQL statements when true

# --- Collector (Kraken) ---
COLLECT_INTERVAL_SECONDS=60 # Poll interval read by Kraken collector loop (apps.collector.main), not settings.py
COLLECT_SPOT_EXCHANGE=kraken # Spot exchange label stored on ingested market ticks
COLLECT_PERP_EXCHANGE=kraken_futures # Perp exchange label stored on ingested ticks/funding
COLLECT_SPOT_SYMBOL=XBTUSD # Spot symbol identifier tracked by collector logic
COLLECT_PERP_SYMBOL=XBTUSD # Perp symbol identifier tracked by collector logic
COLLECT_SPOT_EXCHANGE_SYMBOL=XXBTZUSD # Kraken spot API result key / exchange-native symbol
COLLECT_PERP_EXCHANGE_SYMBOL=PF_XBTUSD # Kraken futures ticker symbol used to select perp data
COLLECT_ADAPTER_NAME=kraken_rest # Adapter name persisted with market/funding snapshots
COLLECT_SPOT_BASE_URL=https://api.kraken.com # Base URL for Kraken spot REST API
COLLECT_FUTURES_BASE_URL=https://futures.kraken.com # Base URL for Kraken futures REST API
COLLECT_REQUEST_TIMEOUT_SECONDS=10 # HTTP timeout for collector REST requests

# --- Coinbase Advanced ---
COINBASE_API_KEY=organizations/xxx/apiKeys/xxx # Coinbase CDP API key path
COINBASE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY----- # Coinbase Ed25519 private key with literal \n separators

# --- Paper Trader ---
KRAKEN_API_KEY=your_key_here # Kraken spot read-only API key
KRAKEN_API_SECRET=your_secret_here # Kraken spot API secret
MM_SPREAD_BPS=20 # Market making spread in basis points
# MM_QUOTE_SIZE=0.001 # Quote size per side in BTC (fallback when MM_QUOTE_SIZE_PCT is unset)
# MM_MAX_INVENTORY=0.01 # Max absolute position in BTC (fallback when MM_MAX_INVENTORY_PCT is unset)
MM_QUOTE_SIZE_PCT=10 # Quote size per order as % of account value
MM_MAX_INVENTORY_PCT=50 # Max BTC inventory as % of account value
MM_MIN_PROFIT_BPS=10 # Extra profit target above break-even round-trip fees (bps)
MM_FEE_BPS=25.0 # Estimated fee per side in basis points used for ask markup
MM_TARGET_PROFIT_BPS=20.0 # Target round-trip profit margin in basis points
MM_BID_OFFSET_BPS=180.0 # Bid placement offset below ask in basis points
MM_MIN_SPREAD_BPS=0.01 # Min market spread to quote into (bps)
MM_STALE_BOOK_SECONDS=120 # Max order book age in seconds
MM_TWAP_LOOKBACK_HOURS=2 # TWAP lookback window for quote reference price (hours: 1/2/4/8/24)
MM_ACCOUNT_NAME=paper_mm # Account name for paper MM positions
UNIFIED_SIZING_ENABLED=false # Feature flag for unified ask-distance and TWAP-slope sizing
ASK_SG_NEAR_BPS=30.0 # Distance-to-ask threshold for near zone (bps)
ASK_SG_FAR_BPS=80.0 # Distance-to-ask threshold for far zone (bps)
TWAP_SLOPE_MILD_THRESHOLD=-5.0 # TWAP slope boundary between mild-falling and neutral (bps/min)
TWAP_SLOPE_STEEP_THRESHOLD=-15.0 # TWAP slope boundary for steep-falling (bps/min)
TWAP_SLOPE_RISING_THRESHOLD=5.0 # TWAP slope boundary between neutral and mild-rising (bps/min)
TWAP_SLOPE_STEEP_RISING_THRESHOLD=15.0 # TWAP slope boundary for steep-rising (bps/min)
SG_CONCAVITY_THRESHOLD=1.0 # Absolute concavity threshold used for SG size modifier
PAPER_STARTING_CAPITAL=1000.00 # Starting paper cash balance used for account value tracking
PAPER_STRATEGY=market_making # Active strategy: funding_capture or market_making
SIGNAL_POLL_INTERVAL=60 # Dry-run signal logger poll interval

# --- Delta Neutral (paper_dn) ---
DN_FUNDING_ENTRY_THRESHOLD_APR=5.0 # Enter when annualized funding APR is at/above this threshold
DN_FUNDING_EXIT_THRESHOLD_APR=2.0 # Exit when annualized funding APR drops below this threshold
DN_CONTRACT_QTY=8 # Target ETH-PERP contract count (each contract = 0.10 ETH)
DN_ITERATION_SECONDS=60 # Delta-neutral loop interval in seconds
DN_FORCE_ENTRY=false # Testing override to bypass entry threshold (paper mode only)
DN_BLOCK_ON_RATIO_VIOLATION=true # Block strategy actions when ratio drifts out of safe bounds
DN_MAX_DAILY_LOSS_USD=50.0 # Daily loss circuit breaker threshold (USD)
DN_SPOT_EXCHANGE=kraken # Spot leg exchange
DN_SPOT_SYMBOL=ETHUSD # Spot leg symbol
DN_PERP_EXCHANGE=coinbase_advanced # Perp leg exchange
DN_PERP_SYMBOL=ETH-PERP # Perp leg symbol

# --- Dashboard ---
# No dashboard-specific environment variables are currently read from code.

# --- Backtester ---
# No backtester-specific environment variables are currently read from code.