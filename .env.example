# --- General ---
APP_NAME=crypto-mvp # Human-readable app name used in settings/bootstrap logs
ENVIRONMENT=development # Runtime environment label (for example development, staging, production)
LOG_LEVEL=INFO # Global log verbosity for service logging
RUN_MODE=paper # High-level execution mode used by application settings
SERVICE_NAME=collector # Service identity used by bootstrap logging/metadata

# --- Database ---
DB_HOST=localhost # Postgres host used by SQLAlchemy connection URL
DB_PORT=5432 # Postgres TCP port used by SQLAlchemy connection URL
DB_NAME=crypto_mvp # Postgres database name used by SQLAlchemy connection URL
DB_USER=postgres # Postgres username used by SQLAlchemy connection URL
DB_PASSWORD=postgres # Postgres password used by SQLAlchemy connection URL
DB_ECHO=false # SQLAlchemy echo flag to print SQL statements when true

# --- Collector (Kraken) ---
COLLECT_EXCHANGE=mock # Legacy collector exchange selector from app settings
COLLECT_SYMBOL=BTC-USD # Legacy collector symbol from app settings
COLLECT_INTERVAL_SECONDS=60 # Poll interval used by collector main loop config
COLLECT_FUNDING=false # Legacy funding-toggle from app settings
COLLECT_FUNDING_SYMBOL=BTCUSDT # Legacy funding symbol from app settings
COLLECT_SPOT_EXCHANGE=kraken # Spot exchange label stored on ingested market ticks
COLLECT_PERP_EXCHANGE=kraken_futures # Perp exchange label stored on ingested ticks/funding
COLLECT_SPOT_SYMBOL=XBTUSD # Spot symbol identifier tracked by collector logic
COLLECT_PERP_SYMBOL=XBTUSD # Perp symbol identifier tracked by collector logic
COLLECT_SPOT_EXCHANGE_SYMBOL=XXBTZUSD # Kraken spot API result key / exchange-native symbol
COLLECT_PERP_EXCHANGE_SYMBOL=PF_XBTUSD # Kraken futures ticker symbol used to select perp data
COLLECT_ADAPTER_NAME=kraken_rest # Adapter name persisted with market/funding snapshots
COLLECT_SPOT_BASE_URL=https://api.kraken.com # Base URL for Kraken spot REST API
COLLECT_FUTURES_BASE_URL=https://futures.kraken.com # Base URL for Kraken futures REST API
COLLECT_REQUEST_TIMEOUT_SECONDS=10 # HTTP timeout for collector REST requests

# --- Paper Trader ---
# No paper-trader-specific environment variables are currently read from code.

# --- Dashboard ---
# No dashboard-specific environment variables are currently read from code.

